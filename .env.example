# =============================================================================
# Stirling-PDF — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Stirling-PDF is a zero-dependency app — no database, no Redis, no volumes
# are required for basic operation. Everything below is optional.
# =============================================================================

# ---------------------------------------------------------------------------
# Security & Authentication
# ---------------------------------------------------------------------------
# Stirling-PDF includes authentication by default (all Docker images
# except ultra-lite). Disable it with:
# SECURITY_ENABLELOGIN=false

# Custom initial admin credentials (set before first deploy):
# Default: admin / stirling
# SECURITY_INITIALLOGIN_USERNAME=admin
# SECURITY_INITIALLOGIN_PASSWORD=stirling

# Lockout settings after failed login attempts:
# LOGIN_ATTEMPT_COUNT=5
# LOGIN_RESET_TIME_MINUTES=10

# ---------------------------------------------------------------------------
# System Configuration
# ---------------------------------------------------------------------------

# Port (default: 8080). Railway sets PORT automatically.
# PORT=8080

# Default locale / language (e.g., 'en-US', 'de-DE', 'fr-FR', 'ja-JP', 'zh-CN')
# SYSTEM_DEFAULTLOCALE=en-US

# Timezone (default: UTC)
# TZ=UTC

# Allow Google to index your instance (via robots.txt)
# SYSTEM_GOOGLEVISIBILITY=false

# Disable CSRF protection (not recommended for production)
# CSRF_DISABLED=false

# ---------------------------------------------------------------------------
# UI Customisation
# ---------------------------------------------------------------------------

# Logo style: 'classic' or 'modern'
# UI_LOGOSTYLE=classic

# ---------------------------------------------------------------------------
# Email Configuration (optional — only needed for user invitations)
# ---------------------------------------------------------------------------

# MAIL_ENABLED=false
# MAIL_FROM=noreply@example.com
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_TLS_ENABLED=true
# MAIL_ENABLEINVITES=false

# ---------------------------------------------------------------------------
# Advanced: Custom Settings File
# ---------------------------------------------------------------------------
# Stirling-PDF can also be configured via a settings.yml file placed at
# /configs/settings.yml. Environment variables take precedence.
