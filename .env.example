# =============================================================================
# Stirling-PDF - Environment Variables
# https://docs.stirlingpdf.com
#
# Stirling-PDF overrides settings.yml entries via SYSTEM_* prefixed env vars.
# See https://github.com/Stirling-Tools/Stirling-PDF/blob/main/configs/settings.yml
# =============================================================================

# ---------------------------------------------------------------------------
# Port & Timezone
# ---------------------------------------------------------------------------
PORT=8080
TZ=UTC

# ---------------------------------------------------------------------------
# Security & Authentication
# Enable login (default: false). Set true to require authentication.
# ---------------------------------------------------------------------------
SYSTEM_SECURITY_LOGINENABLED=false
SYSTEM_SECURITY_INITIALLOGINUSER=admin
SYSTEM_SECURITY_INITIALLOGINPASS=stirling
SYSTEM_SECURITY_ENABLEMULTITENANCY=false

# ---------------------------------------------------------------------------
# System Configuration
# ---------------------------------------------------------------------------
SYSTEM_ROOTPATH=/
SYSTEM_ALLOWOCR=true

# ---------------------------------------------------------------------------
# UI / Appearance
# ---------------------------------------------------------------------------
SYSTEM_UI_APPNAME=Stirling-PDF
SYSTEM_UI_HOMETEXT=
SYSTEM_UI_HIDELANGUAGE=false

# ---------------------------------------------------------------------------
# Email / SMTP (optional)
# ---------------------------------------------------------------------------
SYSTEM_MAIL_ENABLED=false
SYSTEM_MAIL_HOST=
SYSTEM_MAIL_PORT=587
SYSTEM_MAIL_USERNAME=
SYSTEM_MAIL_PASSWORD=
SYSTEM_MAIL_FROM=

# ---------------------------------------------------------------------------
# Endpoint Control (optional)
# Comma-separated list of endpoints to disable, e.g.: OCR,Convert,Compress
# ---------------------------------------------------------------------------
SYSTEM_ENDPOINTDISABLE=
